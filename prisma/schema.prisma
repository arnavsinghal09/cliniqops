generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ENUMS

enum Role {
  ADMIN
  DOCTOR
  BILLING
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
}

enum RoomStatus {
  WAITING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ScribeStatus {
  DRAFT
  PROCESSED
}


// CLINIC & USERS

model Clinic {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  addressLine       String?
  city              String?
  phone             String?
  timezone          String             @default("Asia/Kolkata")
  workingHoursJson  String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  users             User[]
  appointments      Appointment[]
  patients          Patient[]
  alerts            Alert[]
  invitations       Invitation[]
  auditLogs         AuditLog[]
  savedQueries SavedQuery[]
  consultationRooms ConsultationRoom[]
}

model User {
  id                String             @id @default(cuid())
  email             String
  passwordHash      String
  name              String?
  title             String?
  phone             String?
  avatarUrl         String?
  role              Role               @default(DOCTOR)
  status            UserStatus         @default(ACTIVE)
  mustResetPassword Boolean            @default(false)
  clinicId          String
  clinic            Clinic             @relation(fields: [clinicId], references: [id])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt
  appointments      Appointment[]
  accounts          Account[]
  sessions          Session[]
  auditLogs         AuditLog[]         @relation("AuditActor")
  consultationRooms ConsultationRoom[] @relation("DoctorRooms")
  scribeSessions    ScribeSession[]    @relation("DoctorScribes")

  @@unique([email, clinicId])
  @@index([clinicId])
}

model Invitation {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  title     String?
  role      Role     @default(DOCTOR)
  token     String   @unique @default(cuid())
  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@unique([email, clinicId])
  @@index([clinicId])
}


// PATIENTS, APPOINTMENTS, FOLLOW-UPS

model Patient {
  id                String             @id @default(cuid())
  clinicId          String
  clinic            Clinic             @relation(fields: [clinicId], references: [id])
  name              String
  dateOfBirth       DateTime?
  icd10Codes        String[]
  lastVisitDate     DateTime?
  createdAt         DateTime           @default(now())
  appointments      Appointment[]
  followUpActions   FollowUpAction[]
  consultationRooms ConsultationRoom[]
  scribeSessions    ScribeSession[]

  @@index([clinicId])
}

model Appointment {
  id              String            @id @default(cuid())
  clinicId        String
  clinic          Clinic            @relation(fields: [clinicId], references: [id])
  doctorId        String
  doctor          User              @relation(fields: [doctorId], references: [id])
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])
  appointmentDate DateTime
  durationMinutes Int
  appointmentType String
  status          AppointmentStatus
  billedCptCode   String?
  billedAmount    Decimal?
  createdAt       DateTime          @default(now())

  @@unique([clinicId, patientId, appointmentDate, doctorId])
  @@index([clinicId])
  @@index([doctorId])
  @@index([patientId])
}

model FollowUpAction {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  clinicId        String
  notes           String
  actionDate      DateTime @default(now())
  createdByUserId String

  @@index([clinicId])
  @@index([patientId])
}


// ALERTS & AUDIT & QUERY SAVING

model SavedQuery {
  id            String   @id @default(cuid())
  clinicId      String
  clinic        Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  userId        String
  question      String   @db.Text
  sql           String   @db.Text
  chartType     String?
  rowCount      Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([clinicId])
  @@index([userId])
}

model Alert {
  id               String        @id @default(cuid())
  clinicId         String
  clinic           Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  alertType        String
  metric           String
  currentValue     Float
  baselineValue    Float
  deviationPercent Float
  severity         AlertSeverity
  weekOf           DateTime
  isRead           Boolean       @default(false)
  mlDetected       Boolean       @default(false)
  createdAt        DateTime      @default(now())

  @@unique([clinicId, metric, weekOf])
  @@index([clinicId])
}

model AuditLog {
  id         String   @id @default(cuid())
  clinicId   String
  clinic     Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  actorId    String
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
  action     String
  targetType String
  targetId   String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([clinicId])
  @@index([createdAt])
}


// CONSULTATION / SCRIBE / SOAP


model ConsultationRoom {
  id             String         @id @default(cuid())
  clinicId       String
  clinic         Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  doctorId       String
  doctor         User           @relation("DoctorRooms", fields: [doctorId], references: [id])
  patientId      String?
  patient        Patient?       @relation(fields: [patientId], references: [id])
  patientName    String
  patientEmail   String?
  patientPhone   String?
  roomToken      String         @unique @default(cuid())
  status         RoomStatus     @default(WAITING)
  scheduledAt    DateTime?
  startedAt      DateTime?
  endedAt        DateTime?
  reportViewedAt DateTime?
  createdAt      DateTime       @default(now())
  scribeSession  ScribeSession?

  @@index([clinicId])
  @@index([doctorId])
  @@index([roomToken])
}

model ScribeSession {
  id                 String            @id @default(cuid())
  clinicId           String
  doctorId           String
  doctor             User              @relation("DoctorScribes", fields: [doctorId], references: [id])
  patientId          String?
  patient            Patient?          @relation(fields: [patientId], references: [id])
  consultationRoomId String?           @unique
  consultationRoom   ConsultationRoom? @relation(fields: [consultationRoomId], references: [id])
  rawTranscript      String            @db.Text
  status             ScribeStatus      @default(DRAFT)
  createdAt          DateTime          @default(now())
  soapNote           SoapNote?

  @@index([clinicId])
  @@index([doctorId])
}

model SoapNote {
  id                  String        @id @default(cuid())
  scribeSessionId     String        @unique
  scribeSession       ScribeSession @relation(fields: [scribeSessionId], references: [id], onDelete: Cascade)
  clinicId            String
  subjective          String        @db.Text
  objective           String        @db.Text
  assessment          String        @db.Text
  plan                String        @db.Text
  icd10Codes          String[]
  suggestedCptCode    String
  cptRationale        String
  patientInstructions String        @db.Text
  followUpDate        DateTime?
  prescriptions       String[]
  editedAt            DateTime?
  approvedAt          DateTime?
  approvedByUserId    String?
  createdAt           DateTime      @default(now())
  cptCodes            CptCode[]

  @@index([clinicId])
}

enum CptStatus {
  SUGGESTED
  APPROVED
  REJECTED
}

enum CptSource {
  AI
  MANUAL
}

model CptCode {
  id             String    @id @default(cuid())
  soapNoteId     String
  soapNote       SoapNote  @relation(fields: [soapNoteId], references: [id], onDelete: Cascade)
  code           String
  description    String
  status         CptStatus @default(SUGGESTED)
  source         CptSource @default(AI)
  confidence     Float?
  rationale      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([soapNoteId])
}


// AUTH (NextAuth)


model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}